# Copy to .env and fill in. .env is gitignored -- never commit real keys.
#   cp .env.example .env
#
# Each collaborator needs their OWN keys. Do not share keys over git, Slack, or email.

# --- Required for the web-search study (src/run_websearch_study.py) ---
# All three are needed for the 3-model run. To run fewer models, leave a key blank
# and skip that provider, e.g. --anthropic-model ''
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- Required for affiliation resolution (src/resolve_affiliations.py) ---
# Free key at https://openalex.org/settings/api -- without one OpenAlex 429s all day.
# Collaborators resolving papers on the same day need SEPARATE keys; there is no
# shared free pool.
OPENALEX_API_KEY=

